{
  "manifest_version": 3,
  "name": "AITools Pro",
  "version": "4.0.0",
  "description": "Suite complète d'outils IA: Recherche Google, Mode Sombre, Temps de lecture, Notes",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "notifications", "tabGroups", "alarms", "identity"],
  "host_permissions": ["<all_urls>", "https://yvtukwaepqqsvacbbyou.supabase.co/*"],
  "action": {
    "default_popup": "popup-new.html",
    "default_title": "AITools Pro - Outils intelligents",
    "default_icon": {
      "2048": "icons/logo aitools sans fond.png",
      "1024": "icons/logo aitools sans fond sans texte.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["ai-service.js", "layout-manager.js", "content-v4.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background-v4.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles-new.css", "ai-injected.js", "auth-supabase.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "512": "icons/logo aitools sans fond sans texte.png",
    "256": "icons/logo aitools sans fond.png"
  },
  "oauth2": {
    "client_id": "277196877247-sleq8im8phkhs4kqorflcpm448ki1f5i.apps.googleusercontent.com",
    "scopes": ["email", "profile"]
  }
}
